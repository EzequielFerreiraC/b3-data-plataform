B3_API_TOKEN=your_brapi_token_here

# MinIO / S3
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=b3-bronze
MINIO_BUCKET_SILVER=b3-silver
MINIO_BUCKET_GOLD=b3-gold

# Spark
SPARK_APP_NAME=b3-data-platform
SPARK_MASTER=local[*]

# Paths (local dev — overridden by S3 in prod)
DATA_PATH_BRONZE=data/bronze
DATA_PATH_SILVER=data/silver
DATA_PATH_GOLD=data/gold
LOGS_PATH=logs

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
