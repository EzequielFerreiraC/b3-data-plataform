# =============================================================================
# B3 Data Platform — Environment Variables
# Copy this file to .env and adjust values as needed
# =============================================================================

# BRAPI Token (optional — Yahoo Finance works without it)
B3_API_TOKEN=your_brapi_token_here

# MinIO / S3 Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=b3-bronze
MINIO_BUCKET_SILVER=b3-silver
MINIO_BUCKET_GOLD=b3-gold

# Data Paths (relative to project root)
DATA_PATH_BRONZE=j_data/a_bronze
DATA_PATH_SILVER=j_data/b_silver
DATA_PATH_GOLD=j_data/c_gold
LOGS_PATH=k_logs
OUTPUTS_PATH=n_reports

# Airflow Configuration
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Spark Configuration
SPARK_APP_NAME=b3-data-platform
SPARK_MASTER=local[*]
